{
    "name": "Push It Extension",
    "version": "1.0.0",
    "manifest_version": 3,
    "action": {
        "default_popup": "index.html"
    },
    "permissions": [
        "activeTab", "scripting", "storage"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "icons": {
        "16":"favicon-96x96.png",
        "48":"favicon-96x96.png",
        "128":"favicon-96x96.png"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["loader.js"]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["assets/*"],
            "matches": ["<all_urls>"]
        }
    ]
}